<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>clinikit report — {{ title }}</title>
<style>
:root {
  --fg: #1f2933;
  --muted: #6b7785;
  --bg: #ffffff;
  --panel: #f7f9fb;
  --accent: #2b6cb0;
  --border: #d6dde6;
  --good: #2f855a;
  --warn: #c05621;
}
* { box-sizing: border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
    Oxygen-Sans, Ubuntu, Cantarell, sans-serif;
  color: var(--fg);
  background: var(--bg);
  margin: 0;
  padding: 0;
  line-height: 1.5;
}
header {
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  padding: 32px 48px;
}
header h1 {
  margin: 0;
  font-size: 26px;
  font-weight: 600;
}
header .subtitle {
  color: var(--muted);
  margin-top: 4px;
  font-size: 14px;
}
main {
  max-width: 1100px;
  margin: 0 auto;
  padding: 32px 48px 64px;
}
section { margin-top: 36px; }
section h2 {
  font-size: 18px;
  font-weight: 600;
  border-bottom: 1px solid var(--border);
  padding-bottom: 6px;
  margin-bottom: 16px;
}
table {
  border-collapse: collapse;
  width: 100%;
  font-size: 13px;
}
th, td {
  padding: 8px 12px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}
th {
  background: var(--panel);
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  font-size: 11px;
  letter-spacing: 0.04em;
}
td.numeric, th.numeric { text-align: right; font-variant-numeric: tabular-nums; }
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
}
.metric-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 14px 16px;
}
.metric-card .label {
  color: var(--muted);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.metric-card .value {
  font-size: 22px;
  font-weight: 600;
  margin-top: 4px;
  font-variant-numeric: tabular-nums;
}
.disclaimer {
  background: #fffbea;
  border: 1px solid #fbd38d;
  color: var(--warn);
  border-radius: 6px;
  padding: 12px 16px;
  font-size: 13px;
}
.kv {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 6px 16px;
  font-size: 13px;
}
.kv dt { color: var(--muted); }
.kv dd { margin: 0; font-variant-numeric: tabular-nums; }
footer {
  margin-top: 48px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
  color: var(--muted);
  font-size: 12px;
}
code { font-family: SFMono-Regular, Consolas, monospace; font-size: 12px; }
</style>
</head>
<body>
<header>
  <h1>{{ title }}</h1>
  <div class="subtitle">
    Generated by clinikit {{ clinikit_version }} on {{ generated_at }}
  </div>
</header>

<main>

<div class="disclaimer">
  This report is a research-and-development summary. It is not a
  regulated artefact and not a substitute for formal compliance review.
</div>

{% if metrics %}
<section>
  <h2>Headline metrics</h2>
  <div class="metrics-grid">
    {% for name, value in metrics.items() %}
    <div class="metric-card">
      <div class="label">{{ name }}</div>
      <div class="value">{{ "%.4f"|format(value) if value is number else value }}</div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if dataset %}
<section>
  <h2>Dataset</h2>
  <dl class="kv">
    {% for key, value in dataset.items() %}
    <dt>{{ key }}</dt>
    <dd>{{ value }}</dd>
    {% endfor %}
  </dl>
</section>
{% endif %}

{% if model %}
<section>
  <h2>Model</h2>
  <dl class="kv">
    {% for key, value in model.items() %}
    <dt>{{ key }}</dt>
    <dd>{{ value }}</dd>
    {% endfor %}
  </dl>
</section>
{% endif %}

{% if leaderboard %}
<section>
  <h2>Leaderboard</h2>
  <table>
    <thead>
      <tr>
        {% for col in leaderboard_columns %}
        <th class="{{ 'numeric' if col in numeric_columns else '' }}">{{ col }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in leaderboard %}
      <tr>
        {% for col in leaderboard_columns %}
        <td class="{{ 'numeric' if col in numeric_columns else '' }}">
          {% if row[col] is number %}{{ "%.4f"|format(row[col]) }}{% else %}{{ row[col] }}{% endif %}
        </td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

{% if reproducibility %}
<section>
  <h2>Reproducibility</h2>
  <dl class="kv">
    {% for key, value in reproducibility.items() %}
    <dt>{{ key }}</dt>
    <dd><code>{{ value }}</code></dd>
    {% endfor %}
  </dl>
</section>
{% endif %}

{% if audit %}
<section>
  <h2>Audit findings</h2>
  <dl class="kv">
    {% for key, value in audit.items() %}
    <dt>{{ key }}</dt>
    <dd>{{ value }}</dd>
    {% endfor %}
  </dl>
</section>
{% endif %}

</main>

<footer>
  <div>clinikit research report. Templates are for research documentation only.</div>
</footer>

</body>
</html>
